      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[ApprovalCustomer]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(in_ApprovalBodyJson) AndAlso JObject.Parse(in_ApprovalBodyJson)("formData") IsNot Nothing AndAlso JObject.Parse(in_ApprovalBodyJson)("formData")("customer") IsNot Nothing, JObject.Parse(in_ApprovalBodyJson)("formData")("customer").ToString(), "")]</InArgument>
      </Assign.Value>
    </Assign>
    <Assign DisplayName="Extract Amount" sap2010:WorkflowViewState.IdRef="Assign_Amount">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[ApprovalAmount]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(Not String.IsNullOrWhiteSpace(in_ApprovalBodyJson) AndAlso JObject.Parse(in_ApprovalBodyJson)("formData") IsNot Nothing AndAlso JObject.Parse(in_ApprovalBodyJson)("formData")("amount") IsNot Nothing, JObject.Parse(in_ApprovalBodyJson)("formData")("amount").ToString(), "")]</InArgument>
      </Assign.Value>
