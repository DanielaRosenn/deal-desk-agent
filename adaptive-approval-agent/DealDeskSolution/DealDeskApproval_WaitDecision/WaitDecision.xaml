    <!-- Step 5: Inject orchestrator_task_id and job key into HITL body -->
    <ui:InvokeCode ContinueOnError="True" DisplayName="Inject Task ID into HITL Body" sap2010:WorkflowViewState.IdRef="InvokeCode_InjectTaskId"
      Code="Dim result As String = in_Body&#xA;Try&#xA;    Dim bodyObj = Newtonsoft.Json.Linq.JObject.Parse(in_Body)&#xA;    If in_TaskId &gt; 0 Then&#xA;        bodyObj(&quot;orchestrator_task_id&quot;) = in_TaskId&#xA;    End If&#xA;    bodyObj(&quot;orchestrator_job_key&quot;) = in_JobKey&#xA;    bodyObj(&quot;orchestratorFolderId&quot;) = CLng(in_FolderId)&#xA;    bodyObj(&quot;orchestrator_folder_id&quot;) = CLng(in_FolderId)&#xA;    bodyObj(&quot;orchestrator_process_key&quot;) = If(bodyObj(&quot;orchestrator_process_key&quot;) Is Nothing, New Newtonsoft.Json.Linq.JValue(&quot;DealDeskApproval&quot;), bodyObj(&quot;orchestrator_process_key&quot;))&#xA;    result = bodyObj.ToString(Newtonsoft.Json.Formatting.None)&#xA;Catch ex As Exception&#xA;End Try&#xA;out_Body = result">
      <ui:InvokeCode.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_Body">[If(String.IsNullOrWhiteSpace(SanitizedApprovalBodyJson), If(String.IsNullOrWhiteSpace(in_ApprovalBodyJson), &quot;{}&quot;, in_ApprovalBodyJson), SanitizedApprovalBodyJson)]</InArgument>
        <InArgument x:TypeArguments="x:Int64" x:Key="in_TaskId">[If(v_TaskObject IsNot Nothing AndAlso v_TaskObject.Id.HasValue, CLng(v_TaskObject.Id.Value), 0L)]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_JobKey">[If(v_JobInfo IsNot Nothing, v_JobInfo.Key.ToString(), &quot;&quot;)]</InArgument>
        <InArgument x:TypeArguments="x:Int32" x:Key="in_FolderId">[in_OrchestratorFolderId]</InArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_Body">[BodyWithTaskId]</OutArgument>
      </ui:InvokeCode.Arguments>
    </ui:InvokeCode>

    <!-- Step 6: POST to HITL API to create approval -->
    <ui:LogMessage DisplayName="Log: Creating HITL Approval" sap2010:WorkflowViewState.IdRef="Log_PrePost" Level="Info" Message="[&quot;POSTing to HITL API. Title: &quot; &amp; ApprovalTitle &amp; &quot; Approver: &quot; &amp; ApproverEmailFromBody]" />
    <ui:InvokeCode ContinueOnError="False" DisplayName="POST to HITL API /api/v1/approvals" sap2010:WorkflowViewState.IdRef="InvokeCode_HitlPost"
      Code="Dim baseUrl As String = If(String.IsNullOrWhiteSpace(in_ApiUrl), &quot;https://djun97l419cdy.cloudfront.net&quot;, in_ApiUrl).Trim().TrimEnd(&quot;/&quot;c)&#xA;Dim apiUrl As String = If(baseUrl.ToLowerInvariant().EndsWith(&quot;/api/v1/approvals&quot;), baseUrl, baseUrl &amp; &quot;/api/v1/approvals&quot;)&#xA;Dim apiKey As String = If(String.IsNullOrWhiteSpace(in_ApiKey), &quot;hitl_test_api_key_12345&quot;, in_ApiKey).Trim()&#xA;Dim raw As String = If(String.IsNullOrWhiteSpace(in_BodyJson), &quot;{}&quot;, in_BodyJson)&#xA;Dim capturedUrl As String = apiUrl&#xA;Dim capturedKey As String = apiKey&#xA;Dim capturedRaw As String = raw&#xA;Dim httpTask = System.Threading.Tasks.Task.Run(Function() As String&#xA;    Using innerClient As New System.Net.Http.HttpClient()&#xA;        innerClient.Timeout = System.TimeSpan.FromSeconds(25)&#xA;        innerClient.DefaultRequestHeaders.TryAddWithoutValidation(&quot;x-api-key&quot;, capturedKey)&#xA;        innerClient.DefaultRequestHeaders.TryAddWithoutValidation(&quot;Accept&quot;, &quot;application/json&quot;)&#xA;        Dim httpContent As New System.Net.Http.StringContent(capturedRaw, System.Text.Encoding.UTF8, &quot;application/json&quot;)&#xA;        Dim resp = innerClient.PostAsync(capturedUrl, httpContent).GetAwaiter().GetResult()&#xA;        Dim respBody As String = resp.Content.ReadAsStringAsync().GetAwaiter().GetResult()&#xA;        Return If(Not String.IsNullOrWhiteSpace(respBody), respBody, &quot;HITL_POST_ERROR:HTTP_&quot; &amp; CInt(resp.StatusCode).ToString() &amp; &quot;_EmptyBody&quot;)&#xA;    End Using&#xA;End Function)&#xA;If Not httpTask.Wait(System.TimeSpan.FromSeconds(30)) Then&#xA;    out_Response = &quot;HITL_EXCEPTION:TimeoutException=HITL POST did not respond within 30 seconds&quot;&#xA;ElseIf httpTask.IsFaulted Then&#xA;    out_Response = &quot;HITL_EXCEPTION:&quot; &amp; httpTask.Exception.InnerException.GetType().Name &amp; &quot;=&quot; &amp; httpTask.Exception.InnerException.Message&#xA;Else&#xA;    out_Response = httpTask.Result&#xA;End If">
      <ui:InvokeCode.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiUrl">[HitlApiUrlEffective]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiKey">[HitlApiKeyEffective]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_BodyJson">[BodyWithTaskId]</InArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_Response">[HitlResponseJson]</OutArgument>
      </ui:InvokeCode.Arguments>
    </ui:InvokeCode>
    <ui:LogMessage DisplayName="Log: HITL Response" sap2010:WorkflowViewState.IdRef="Log_HitlResp" Level="Info" Message="[&quot;HITL POST response: &quot; &amp; HitlResponseJson]" />

    <!-- Step 7: Validate HITL response shape -->
    <ui:InvokeCode ContinueOnError="False" DisplayName="Validate HITL Response Shape" sap2010:WorkflowViewState.IdRef="InvokeCode_ValidateHitlResponse"
      Code="If String.IsNullOrWhiteSpace(in_ResponseJson) Then Throw New BusinessRuleException(&quot;HITL response is empty. Verify HITL API URL/key and endpoint availability.&quot;)&#xA;If in_ResponseJson.StartsWith(&quot;HITL_EXCEPTION:&quot;) Then Throw New BusinessRuleException(&quot;HITL POST exception: &quot; &amp; in_ResponseJson)&#xA;If in_ResponseJson.StartsWith(&quot;HITL_POST_ERROR:&quot;) Then Throw New BusinessRuleException(&quot;HITL POST failed: &quot; &amp; in_ResponseJson)&#xA;Dim responseObj = Newtonsoft.Json.Linq.JObject.Parse(in_ResponseJson)&#xA;If responseObj(&quot;id&quot;) Is Nothing Then Throw New BusinessRuleException(&quot;HITL response missing field 'id'. Response: &quot; &amp; in_ResponseJson)&#xA;Dim approvalLines = TryCast(responseObj(&quot;approvalLines&quot;), Newtonsoft.Json.Linq.JArray)&#xA;If approvalLines Is Nothing OrElse approvalLines.Count = 0 Then Throw New BusinessRuleException(&quot;HITL response missing 'approvalLines'. Response: &quot; &amp; in_ResponseJson)&#xA;Dim firstLine = approvalLines(0)&#xA;If firstLine(&quot;responseToken&quot;) Is Nothing Then Throw New BusinessRuleException(&quot;HITL response missing 'approvalLines[0].responseToken'. Response: &quot; &amp; in_ResponseJson)">
      <ui:InvokeCode.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_ResponseJson">[HitlResponseJson]</InArgument>
      </ui:InvokeCode.Arguments>
    </ui:InvokeCode>

