    <!-- Step 1: Extract title and approver email from body before any API calls -->
    <ui:InvokeCode ContinueOnError="True" DisplayName="Extract Title and Approver Email from Body" sap2010:WorkflowViewState.IdRef="InvokeCode_ExtractTitleEmail"
      Code="Dim title As String = &quot;Deal Desk Approval&quot;&#xA;Dim approverAddr As String = &quot;daniela.rosenstein@catonetworks.com&quot;&#xA;Try&#xA;    If Not String.IsNullOrWhiteSpace(in_BodyJson) Then&#xA;        Dim body = Newtonsoft.Json.Linq.JObject.Parse(in_BodyJson)&#xA;        If body(&quot;title&quot;) IsNot Nothing Then&#xA;            title = body(&quot;title&quot;).ToString()&#xA;        End If&#xA;        Dim approvers = TryCast(body(&quot;approvers&quot;), Newtonsoft.Json.Linq.JArray)&#xA;        If approvers IsNot Nothing AndAlso approvers.Count &gt; 0 Then&#xA;            Dim first = TryCast(approvers(0), Newtonsoft.Json.Linq.JObject)&#xA;            If first IsNot Nothing AndAlso first(&quot;email&quot;) IsNot Nothing Then&#xA;                Dim addr = first(&quot;email&quot;).ToString().Trim()&#xA;                If addr.Contains(&quot;@&quot;) Then approverAddr = addr&#xA;            End If&#xA;        End If&#xA;    End If&#xA;Catch ex As Exception&#xA;End Try&#xA;out_Title = title&#xA;out_ApproverEmail = approverAddr">
      <ui:InvokeCode.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_BodyJson">[in_ApprovalBodyJson]</InArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_Title">[ApprovalTitle]</OutArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_ApproverEmail">[ApproverEmailFromBody]</OutArgument>
      </ui:InvokeCode.Arguments>
    </ui:InvokeCode>

    <!-- Step 2: Normalize HITL request inputs -->
    <ui:InvokeCode ContinueOnError="False" DisplayName="Normalize HITL Request Inputs" sap2010:WorkflowViewState.IdRef="InvokeCode_NormalizeHitlInputs"
      Code="Dim bodyObj As Newtonsoft.Json.Linq.JObject&#xA;Try&#xA;    If String.IsNullOrWhiteSpace(in_ApprovalBodyJson) Then&#xA;        bodyObj = New Newtonsoft.Json.Linq.JObject()&#xA;    Else&#xA;        bodyObj = Newtonsoft.Json.Linq.JObject.Parse(in_ApprovalBodyJson)&#xA;    End If&#xA;Catch ex As Exception&#xA;    bodyObj = New Newtonsoft.Json.Linq.JObject()&#xA;End Try&#xA;If bodyObj(&quot;processId&quot;) Is Nothing Then bodyObj(&quot;processId&quot;) = &quot;DealDeskApproval&quot;&#xA;If bodyObj(&quot;process_id&quot;) Is Nothing Then bodyObj(&quot;process_id&quot;) = &quot;DealDeskApproval&quot;&#xA;If bodyObj(&quot;title&quot;) Is Nothing Then bodyObj(&quot;title&quot;) = If(String.IsNullOrWhiteSpace(in_DefaultTitle), &quot;Deal Desk Approval&quot;, in_DefaultTitle)&#xA;If bodyObj(&quot;approvalType&quot;) Is Nothing Then bodyObj(&quot;approvalType&quot;) = &quot;sequential&quot;&#xA;If bodyObj(&quot;approval_type&quot;) Is Nothing Then bodyObj(&quot;approval_type&quot;) = &quot;sequential&quot;&#xA;Dim approvers = TryCast(bodyObj(&quot;approvers&quot;), Newtonsoft.Json.Linq.JArray)&#xA;If approvers Is Nothing OrElse approvers.Count = 0 Then&#xA;    bodyObj(&quot;approvers&quot;) = New Newtonsoft.Json.Linq.JArray(New Newtonsoft.Json.Linq.JObject(New Newtonsoft.Json.Linq.JProperty(&quot;email&quot;, &quot;daniela.rosenstein@catonetworks.com&quot;), New Newtonsoft.Json.Linq.JProperty(&quot;name&quot;, &quot;Daniela Rosenstein&quot;), New Newtonsoft.Json.Linq.JProperty(&quot;sequenceOrder&quot;, 1), New Newtonsoft.Json.Linq.JProperty(&quot;notificationChannel&quot;, &quot;both&quot;), New Newtonsoft.Json.Linq.JProperty(&quot;notification_channel&quot;, &quot;both&quot;)))&#xA;End If&#xA;If bodyObj(&quot;formData&quot;) Is Nothing Then bodyObj(&quot;formData&quot;) = New Newtonsoft.Json.Linq.JObject()&#xA;Dim formDataObj = TryCast(bodyObj(&quot;formData&quot;), Newtonsoft.Json.Linq.JObject)&#xA;If formDataObj IsNot Nothing AndAlso formDataObj(&quot;approval_id&quot;) Is Nothing Then formDataObj(&quot;approval_id&quot;) = &quot;AUTO-&quot; &amp; Guid.NewGuid().ToString(&quot;N&quot;)&#xA;out_ApprovalBodyJson = bodyObj.ToString(Newtonsoft.Json.Formatting.None)&#xA;out_ApiUrl = If(String.IsNullOrWhiteSpace(in_ApiUrl), &quot;https://djun97l419cdy.cloudfront.net&quot;, in_ApiUrl).Trim()&#xA;out_ApiKey = If(String.IsNullOrWhiteSpace(in_ApiKey), &quot;hitl_test_api_key_12345&quot;, in_ApiKey).Trim()">
      <ui:InvokeCode.Arguments>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApprovalBodyJson">[in_ApprovalBodyJson]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_DefaultTitle">[ApprovalTitle]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiKey">[in_HitlApiKey]</InArgument>
        <InArgument x:TypeArguments="x:String" x:Key="in_ApiUrl">[in_HitlApiUrl]</InArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_ApprovalBodyJson">[SanitizedApprovalBodyJson]</OutArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_ApiKey">[HitlApiKeyEffective]</OutArgument>
        <OutArgument x:TypeArguments="x:String" x:Key="out_ApiUrl">[HitlApiUrlEffective]</OutArgument>
      </ui:InvokeCode.Arguments>
    </ui:InvokeCode>

