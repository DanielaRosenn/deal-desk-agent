    <Assign DisplayName="Extract RecommendedDecision" sap2010:WorkflowViewState.IdRef="Assign_Recommendation">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[ApprovalRecommendation]</OutArgument>
