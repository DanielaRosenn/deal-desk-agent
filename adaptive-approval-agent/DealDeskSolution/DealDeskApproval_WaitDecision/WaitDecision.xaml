      <If.Else>
        <Sequence DisplayName="Poll HITL API for Decision" sap2010:WorkflowViewState.IdRef="Seq_PollHitl">
          <ui:LogMessage DisplayName="Log: Polling HITL API" sap2010:WorkflowViewState.IdRef="Log_NoTask" Level="Warn" Message="[&quot;No Action Center task - polling HITL API every 30s for approval. Id: &quot; &amp; HitlApprovalId]" />
          <ui:InvokeCode ContinueOnError="True" DisplayName="Poll HITL API Until Decision" sap2010:WorkflowViewState.IdRef="InvokeCode_PollHitl"
            Code="Dim baseUrl As String = If(String.IsNullOrWhiteSpace(in_ApiUrl), &quot;https://djun97l419cdy.cloudfront.net&quot;, in_ApiUrl).Trim().TrimEnd(&quot;/&quot;c)&#xA;baseUrl = If(baseUrl.ToLowerInvariant().EndsWith(&quot;/api/v1/approvals&quot;), baseUrl.Substring(0, baseUrl.Length - &quot;/api/v1/approvals&quot;.Length), baseUrl)&#xA;Dim apiKey As String = If(String.IsNullOrWhiteSpace(in_ApiKey), &quot;&quot;, in_ApiKey).Trim()&#xA;Dim checkUrl As String = baseUrl &amp; &quot;/api/v1/approvals/&quot; &amp; in_ApprovalId&#xA;Dim maxMinutes As Integer = 1440&#xA;Dim intervalSeconds As Integer = 30&#xA;Dim startTime As DateTime = DateTime.Now&#xA;Do&#xA;    System.Threading.Thread.Sleep(intervalSeconds * 1000)&#xA;    Try&#xA;        Using client As New System.Net.Http.HttpClient()&#xA;            client.Timeout = TimeSpan.FromSeconds(30)&#xA;            If Not String.IsNullOrWhiteSpace(apiKey) Then&#xA;                client.DefaultRequestHeaders.TryAddWithoutValidation(&quot;x-api-key&quot;, apiKey)&#xA;            End If&#xA;            Dim resp = client.GetAsync(checkUrl).Result&#xA;            If resp.IsSuccessStatusCode Then&#xA;                Dim body As String = resp.Content.ReadAsStringAsync().Result&#xA;                Dim json = Newtonsoft.Json.Linq.JObject.Parse(body)&#xA;                Dim status As String = json(&quot;status&quot;).ToString().ToLower()&#xA;                If status = &quot;approved&quot; OrElse status = &quot;rejected&quot; OrElse status = &quot;request_info&quot; Then&#xA;                    out_Decision = status&#xA;                    Dim lines = TryCast(json(&quot;approvalLines&quot;), Newtonsoft.Json.Linq.JArray)&#xA;                    If lines IsNot Nothing AndAlso lines.Count &gt; 0 Then&#xA;                        Dim line = TryCast(lines(0), Newtonsoft.Json.Linq.JObject)&#xA;                        If line IsNot Nothing AndAlso line(&quot;responseData&quot;) IsNot Nothing Then&#xA;                            Dim rd = TryCast(line(&quot;responseData&quot;), Newtonsoft.Json.Linq.JObject)&#xA;                            If rd IsNot Nothing AndAlso rd(&quot;comments&quot;) IsNot Nothing Then&#xA;                                out_Comments = rd(&quot;comments&quot;).ToString()&#xA;                            End If&#xA;                        End If&#xA;                    End If&#xA;                    Exit Do&#xA;                End If&#xA;            End If&#xA;        End Using&#xA;    Catch ex As Exception&#xA;    End Try&#xA;Loop While (DateTime.Now - startTime).TotalMinutes &lt; maxMinutes">
            <ui:InvokeCode.Arguments>
              <InArgument x:TypeArguments="x:String" x:Key="in_ApiUrl">[HitlApiUrlEffective]</InArgument>
