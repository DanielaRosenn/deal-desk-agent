      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(JObject.Parse(HitlResponseJson)("approvalLines")(0)("approverEmail") IsNot Nothing, JObject.Parse(HitlResponseJson)("approvalLines")(0)("approverEmail").ToString(), ApproverEmailFromBody)]</InArgument>
      </Assign.Value>
    </Assign>

