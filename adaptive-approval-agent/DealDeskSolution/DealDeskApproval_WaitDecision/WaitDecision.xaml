      Code="Dim decision As String = If(Not String.IsNullOrWhiteSpace(in_TaskAction), in_TaskAction.Trim().ToLower(), &quot;escalate&quot;)&#xA;Dim comments As String = &quot;&quot;&#xA;Try&#xA;    If in_TaskObj IsNot Nothing AndAlso in_TaskObj.Data IsNot Nothing Then&#xA;        Dim taskData As Newtonsoft.Json.Linq.JObject&#xA;        If TypeOf in_TaskObj.Data Is Newtonsoft.Json.Linq.JObject Then&#xA;            taskData = CType(in_TaskObj.Data, Newtonsoft.Json.Linq.JObject)&#xA;        Else&#xA;            taskData = Newtonsoft.Json.Linq.JObject.Parse(in_TaskObj.Data.ToString())&#xA;        End If&#xA;        If taskData(&quot;action&quot;) IsNot Nothing AndAlso Not String.IsNullOrWhiteSpace(taskData(&quot;action&quot;).ToString()) Then&#xA;            decision = taskData(&quot;action&quot;).ToString().Trim().ToLower()&#xA;        End If&#xA;        If taskData(&quot;comments&quot;) IsNot Nothing Then&#xA;            comments = taskData(&quot;comments&quot;).ToString()&#xA;        ElseIf taskData(&quot;responseData&quot;) IsNot Nothing Then&#xA;            Dim rd = TryCast(taskData(&quot;responseData&quot;), Newtonsoft.Json.Linq.JObject)&#xA;            If rd IsNot Nothing AndAlso rd(&quot;comments&quot;) IsNot Nothing Then comments = rd(&quot;comments&quot;).ToString()&#xA;        End If&#xA;    End If&#xA;Catch ex As Exception&#xA;End Try&#xA;out_Decision = decision&#xA;out_Comments = comments">
