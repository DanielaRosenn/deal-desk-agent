   c.DefaultRequestHeaders.TryAddWithoutValidation(&quot;Authorization&quot;, &quot;Bearer &quot; &amp; token)&#xA;                Dim content = New System.Net.Http.StringContent(openPayload, System.Text.Encoding.UTF8, &quot;application/json&quot;)&#xA;                Dim r = c.PostAsync(&quot;https://slack.com/api/conversations.open&quot;, content).GetAwaiter().GetResult()&#xA;                Return r.Content.ReadAsStringAsync().GetAwaiter().GetResult()&#xA;            End Using&#xA;        End Function)&#xA;        If task2.Wait(18000) AndAlso Not task2.IsFaulted Then&#xA;            Dim j2 = Newtonsoft.Json.Linq.JObject.Parse(task2.Result)&#xA;            If j2(&quot;ok&quot;) IsNot Nothing AndAlso CBool(j2(&quot;ok&quot;)) Then channelId = j2(&quot;channel&quot;)(&quot;id&quot;).ToString()&#xA;        End If&#xA;        If String.IsNullOrWhiteSpace(channelId) Then Exit Try&#xA;        Dim discountDisplay As String = If(String.IsNullOrWhiteSpace(in_Discount) OrElse in_Discount = &quot;N/A&quot;, in_Discount, in_Discount &amp; &quot;%&quot;)&#xA;        Dim ratDisplay As String = If(String.IsNullOrWhiteSpace(ratSafe) OrElse ratSafe = &quot;N/A&quot;, &quot;_not provided_&quot;, ratSafe)&#xA;        Dim churnS As String = in_ChurnRisk.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Replace(System.Environment.NewLine, &quot; &quot;)&#xA;        Dim tierS As String = in_CustTier.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Replace(System.Environment.NewLine, &quot; &quot;)&#xA;        Dim healthS As String = in_HealthScore.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Replace(System.Environment.NewLine, &quot; &quot;)&#xA;        Dim termS As String = in_RenewalTerm.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Replace(System.Environment.NewLine, &quot; &quot;)&#xA;        Dim compS As String = in_CompInvolved.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Replace(System.Environment.NewLine, &quot; &quot;)&#xA;        Dim msgPayload As String = &quot;{&quot;&quot;channel&quot;&quot;:&quot;&quot;&quot; &amp; channelId &amp; &quot;&quot;&quot;,&quot;&quot;blocks&quot;&quot;:[&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;header&quot;&quot;,&quot;&quot;text&quot;&quot;:{&quot;&quot;type&quot;&quot;:&quot;&quot;plain_text&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;Deal Desk Request - Approval Needed&quot;&quot;}},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;section&quot;&quot;,&quot;&quot;fields&quot;&quot;:[&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Customer:*\n&quot; &amp; custSafe &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Amount:*\n$&quot; &amp; in_Amount &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Discount:*\n&quot; &amp; discountDisplay &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Recommendation:*\n&quot; &amp; in_Recommendation &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Approver:*\n&quot; &amp; in_Email &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Approval ID:*\n&quot; &amp; in_ApprovalId &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Churn risk:*\n&quot; &amp; churnS &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Customer tier:*\n&quot; &amp; tierS &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Health score:*\n&quot; &amp; healthS &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Renewal term (mo):*\n&quot; &amp; termS &amp; &quot;&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;*Competitor:*\n&quot; &amp; compS &amp; &quot;&quot;&quot;}]},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;section&quot;&quot;,&quot;&quot;text&quot;&quot;:{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;:memo: *Rationale:* &quot; &amp; ratDisplay &amp; &quot;&quot;&quot;}},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;divider&quot;&quot;},&quot; &amp;&#xA;            &quot;{&quot;&quot;type&quot;&quot;:&quot;&quot;section&quot;&quot;,&quot;&quot;text&quot;&quot;:{&quot;&quot;type&quot;&quot;:&quot;&quot;mrkdwn&quot;&quot;,&quot;&quot;text&quot;&quot;:&quot;&quot;:envelope: Open your *Outlook email* to approve or reject via the interactive card.&quot;&quot;}}]}&quot;&#xA;        Dim task3 = System.Threading.Tasks.Task.Run(Function() As String&#xA;            Using c As New System.Net.Http.HttpClient()&#xA;                c.Timeout = TimeSpan.FromSeconds(15)&#xA;                c.DefaultRequestHeaders.TryAddWithoutValidation(&quot;Authorization&quot;, &quot;Bearer &quot; &amp; token)&#xA;                Dim content = New System.Net.Http.StringContent(msgPayload, System.Text.Encoding.UTF8, &quot;application/json&quot;)&#xA;                Dim r = c.PostAsync(&quot;https://slack.com/api/chat.postMessage&quot;, content).GetAwaiter().GetResult()&#xA;                Return r.Content.ReadAsStringAsync().GetAwaiter().GetResult()&#xA;            End Using&#xA;        End Function)&#xA;        task3.Wait(18000)&#xA;    Catch ex As Exception&#xA;    End Try&#xA;End If">
