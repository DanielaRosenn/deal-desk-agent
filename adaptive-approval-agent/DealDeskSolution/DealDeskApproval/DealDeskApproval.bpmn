    <bpmn:serviceTask id="Task_EvaluateAndDraft" name="Evaluate and draft (agent plan)">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="ReleaseKey" type="string" value="761D42AC-BEDD-4256-885F-E3C650C64018" />
            <uipath:input name="FolderKey" type="string" value="5fc9fcc4-7156-40c2-9930-7ce61dbbf78b" />
