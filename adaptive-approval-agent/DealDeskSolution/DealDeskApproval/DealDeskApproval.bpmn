        <uipath:binding id="Binding_ProcessResponseFolder" name="DealDeskAgent_process_response" resource="process" resourceSubType="Agent" resourceKey="99558773-C1CB-4F4B-994F-8DBB2EB242FD" propertyAttribute="folderPath" value="Shared/DealDeskApprovalGlobal" />
