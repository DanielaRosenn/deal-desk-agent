            <uipath:input name="Name" type="string" value="DealDeskAgent_plan" />
          </uipath:context>
            <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"request":"=js:((vars.Var_Request||{}).request || vars.Var_Request)"}]]></uipath:input>
          <uipath:output name="agentPlan" type="json" var="Var_AgentPlan" source="=result" />
