# UiPath Orchestrator
UIPATH_BASE_URL=https://cloud.uipath.com
UIPATH_TENANT=catonetworks
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
UIPATH_ORGANIZATION_ID=
UIPATH_FOLDER=Shared

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Salesforce (sandbox for dev)
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_LOGIN_URL=https://test.salesforce.com

# Outlook Actionable Messages
OAM_SENDER_DOMAIN=approvals-dev.cato.network
OAM_PRIVATE_KEY=
OAM_PROVIDER_GUID=

# HiBob (production)
HIBOB_SERVICE_USER=
HIBOB_SERVICE_TOKEN=

# Callback HMAC
HMAC_KEY_ID=v1
HMAC_SECRET=

# Manager resolver — 'mock' for dev/demo, 'hibob' for prod
MANAGER_RESOLVER=mock
MOCK_ORG_CHART_PATH=tests/fixtures/hibob/org_chart.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json   # 'json' for production, 'console' for dev
