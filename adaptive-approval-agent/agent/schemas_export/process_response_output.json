          "type": "string"
        },
        "email": {
          "format": "email",
          "title": "Email",
          "type": "string"
        },
        "persona": {
          "enum": [
            "manager",
            "director",
            "vp",
            "cfo",
            "legal"
          ],
          "title": "Persona",
          "type": "string"
        },
        "role": {
          "maxLength": 50,
          "minLength": 1,
          "title": "Role",
          "type": "string"
        },
        "display_name": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "geo": {
          "anyOf": [
            {
              "maxLength": 10,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geo"
        },
        "timezone": {
          "anyOf": [
            {
              "maxLength": 50,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timezone"
        }
      },
      "required": [
        "user_id",
        "email",
        "persona",
        "role",
        "display_name"
      ],
      "title": "Approver",
      "type": "object"
