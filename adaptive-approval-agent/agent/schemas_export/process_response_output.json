    "info_request_message": {
      "anyOf": [
        {
          "maxLength": 1000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Info Request Message"
    },
    "learning_signals": {
      "additionalProperties": true,
      "title": "Learning Signals",
      "type": "object"
