# Copy to .env and fill in your values — never commit .env
UIPATH_URL=https://cloud.uipath.com
UIPATH_TENANT_NAME=YourTenant
UIPATH_CLIENT_ID=your-client-id
UIPATH_CLIENT_SECRET=your-client-secret
UIPATH_FOLDER=Shared/DealDeskApprovalGlobal

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# AWS HITL service (CloudFront bridge)
HITL_API_KEY=your-hitl-api-key
HITL_BASE_URL=https://your-cloudfront-distribution.cloudfront.net
